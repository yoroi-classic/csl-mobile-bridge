{
  "name": "@emurgo/csl-mobile-bridge-example",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "build:android": "cd android && ./gradlew assembleDebug --no-daemon --console=plain -PreactNativeArchitectures=arm64-v8a --debug",
    "build:ios": "cd ios && xcodebuild -workspace CslMobileBridgeExample.xcworkspace -scheme CslMobileBridgeExample -configuration Debug -sdk iphonesimulator CC=clang CPLUSPLUS=clang++ LD=clang LDPLUSPLUS=clang++ GCC_OPTIMIZATION_LEVEL=0 GCC_PRECOMPILE_PREFIX_HEADER=YES ASSETCATALOG_COMPILER_OPTIMIZATION=time DEBUG_INFORMATION_FORMAT=dwarf COMPILER_INDEX_STORE_ENABLE=NO"
  },
  "dependencies": {
    "blake2b": "^2.1.4",
    "react": "18.3.1",
    "react-native": "0.79.5"
  },
  "devDependencies": {
    "@babel/core": "^7.28.0",
    "@babel/eslint-parser": "^7.28.0",
    "@babel/preset-env": "^7.28.0",
    "@babel/runtime": "^7.28.2",
    "@react-native/babel-preset": "^0.79.5",
    "@react-native/metro-config": "^0.79.5",
    "@react-native/typescript-config": "^0.79.5",
    "babel-plugin-module-resolver": "^5.0.2",
    "eslint-plugin-formatjs": "^5.4.0",
    "eslint-plugin-ft-flow": "^3.0.11",
    "eslint-plugin-react-prefer-function-component": "^4.0.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "pod-install": "^0.1.39"
  },
  "engines": {
    "node": ">=18"
  }
}
