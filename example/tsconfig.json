{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".", 
    "paths": {
      "@/*": ["./*"],
      "@emurgo/csl-mobile-bridge-jsi": ["../src"], 
      // or if you want the built declarations instead of source:
      // "@emurgo/csl-mobile-bridge-jsi": ["../lib/typescript/src"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
