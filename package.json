{
  "name": "@emurgo/csl-mobile-bridge-jsi",
  "version": "1.0.0-alpha.6",
  "description": "React-native bindings for Emurgo's cardano-serialization-lib",
  "main": "./lib/commonjs/index.js",
  "module": "./lib/module/index.js",
  "types": "./lib/typescript/commonjs/src/index.d.ts",
  "source": "src/index",
  "files": [
    "src",
    "lib",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "android",
    "ios",
    "cpp",
    "rust",
    "*.podspec",
    "*.cmake",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!rust/target",
    "!**/.*"
  ],
  "scripts": {
    "example": "yarn workspace @emurgo/csl-mobile-bridge-example",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "clean": "del-cli android/build example/android/build example/android/app/build example/ios/build lib",
    "prepare": "bob build",
    "release": "release-it"
  },
  "keywords": [
    "react-native",
    "ios",
    "android"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Emurgo/csl-mobile-bridge.git",
    "baseUrl": "https://github.com/Emurgo/csl-mobile-bridge"
  },
  "author": "EMURGO",
  "license": "MIT",
  "licenseFilename": "LICENSE",
  "readmeFilename": "README.md",
  "bugs": {
    "url": "https://github.com/Emurgo/csl-mobile-bridge/issues"
  },
  "homepage": "https://github.com/Emurgo/csl-mobile-bridge#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@babel/eslint-parser": "^7.28.0",
    "@commitlint/config-conventional": "^17.8.1",
    "@evilmartians/lefthook": "^1.12.2",
    "@react-native/eslint-config": "^0.72.2",
    "@release-it/conventional-changelog": "^5.1.1",
    "@types/base-64": "^1.0.2",
    "@types/jest": "^28.1.8",
    "@types/react": "~17.0.87",
    "@types/react-native": "0.70.19",
    "commitlint": "^17.8.1",
    "del-cli": "^5.1.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^8.10.2",
    "eslint-plugin-prettier": "^4.2.5",
    "flowgen": "^1.21.0",
    "jest": "^28.1.3",
    "pod-install": "^0.1.39",
    "prettier": "^2.8.8",
    "react": "18.3.1",
    "react-native": "0.73.11",
    "react-native-builder-bob": "^0.40.13",
    "release-it": "^15.11.0",
    "turbo": "^1.13.4",
    "typescript": "^5.9.2"
  },
  "resolutions": {
    "@types/react": "17.0.21"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "workspaces": [
    "example"
  ],
  "packageManager": "yarn@3.6.1",
  "engines": {
    "node": ">= 18.0.0"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "release-it": {
    "git": {
      "commitMessage": "chore: release ${version}",
      "tagName": "v${version}"
    },
    "npm": {
      "publish": true
    },
    "github": {
      "release": true
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": "angular"
      }
    }
  },
  "eslintConfig": {
    "root": true,
    "extends": [
      "@react-native",
      "prettier"
    ],
    "rules": {
      "prettier/prettier": [
        "error",
        {
          "quoteProps": "consistent",
          "singleQuote": true,
          "tabWidth": 2,
          "trailingComma": "es5",
          "useTabs": false
        }
      ]
    }
  },
  "eslintIgnore": [
    "node_modules/",
    "lib/"
  ],
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "commonjs",
        {
          "esm": true
        }
      ],
      "typescript"
    ]
  },
  "codegenConfig": {
    "name": "RNCslMobileBridgeSpec",
    "type": "modules",
    "jsSrcsDir": "src"
  },
  "dependencies": {
    "base-64": "^1.0.0"
  },
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": {
        "types": "./lib/typescript/module/src/index.d.ts",
        "default": "./lib/module/index.js"
      },
      "require": {
        "types": "./lib/typescript/commonjs/src/index.d.ts",
        "default": "./lib/commonjs/index.js"
      }
    },
    "./package.json": "./package.json"
  }
}
